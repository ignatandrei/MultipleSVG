<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">MSVG.BlazorShow</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="icons">
                <MSvg.Blazor.Components.SvgIconPreview Icon="MSvg.All.Microsoft_365_content_icons.Lightbulb_Dark_SVG_Icons" Size="40"
                CssClass = "icon-svg" Title = "Arrow_Circle_Right_Light_Purple_Icon" />
                <span class="bi bi-grid-3x3-gap-fill-nav-menu" aria-hidden="true"></span> Icons
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="getting-started">

                <MSvg.Blazor.Components.SvgIconPreview Icon="MSvg.All.Microsoft_365_content_icons.Document_Bullet_List_Light_Blue_Icon" Size="40" CssClass="icon-svg" Title="document-full" />
                Getting started
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
