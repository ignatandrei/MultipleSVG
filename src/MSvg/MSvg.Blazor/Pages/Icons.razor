@page "/icons"
@namespace MSvg.Blazor.Pages
@using System.Text

<PageTitle>Icon browser</PageTitle>

<h1>Icon browser</h1>

<p class="page-summary">@FilteredIcons.Count of @allIcons.Count icons across @Libraries.Length libraries.</p>

<div class="search-panel">
    <label class="search-label" for="icon-search">Search by icon name or library</label>
    <input id="icon-search"
           class="form-control search-box"
           @bind="SearchText"
           @bind:event="oninput"
           placeholder="Try camera, arrow-right, heroicons, or a misspelling..." />
</div>

<div class="library-summary">
    @foreach (var summary in libraryCounts)
    {
        <span class="library-chip">@summary.Library: @summary.Count</span>
    }
</div>

@if (usingFuzzyMatches)
{
    <p class="search-hint">
        No direct matches for <strong>@searchText.Trim()</strong>. Showing the closest names by Levenshtein distance:
        @string.Join(", ", fuzzyMatches)
    </p>
}
else if (hasSearchText && FilteredIcons.Count == 0)
{
    <p class="search-hint">No icons matched <strong>@searchText.Trim()</strong>.</p>
}

<div class="icon-results">
    <Virtualize Items="@FilteredIcons" Context="entry" ItemSize="92">
        <div class="icon-card">
            <div class="icon-preview">
                <SvgIconPreview Icon="@entry.Icon" Size="40" CssClass="icon-svg" Title="@entry.Icon.Name" />
            </div>
            <div class="icon-details">
                <div class="icon-name">@entry.Icon.Name</div>
                <div class="icon-library">@entry.Library</div>
            </div>
        </div>
    </Virtualize>
</div>

@code {
    private static readonly IconLibraryDefinition[] Libraries =
    [
        new("Bootstrap", BootStrapIcons.IconNames, BootStrapIcons.FromName),
        new("Lucide", LucideIcons.IconNames, LucideIcons.FromName),
        new("Tailwindlabs Heroicons", TailwindlabsHeroicons.IconNames, TailwindlabsHeroicons.FromName),
        new("Glincker The SVG", GlinckerTheSvgIcons.IconNames, GlinckerTheSvgIcons.FromName)
    ];

    private List<IconEntry> allIcons = [];
    private IconEntry[] filteredIcons = [];
    private IReadOnlyList<(string Library, int Count)> libraryCounts = Array.Empty<(string Library, int Count)>();
    private IReadOnlyList<string> fuzzyMatches = Array.Empty<string>();
    private string searchText = string.Empty;
    private bool usingFuzzyMatches;

    private ICollection<IconEntry> FilteredIcons => filteredIcons;

    private bool hasSearchText => !string.IsNullOrWhiteSpace(searchText);

    private string SearchText
    {
        get => searchText;
        set
        {
            if (searchText == value)
            {
                return;
            }

            searchText = value;
            RefreshResults();
        }
    }

    protected override void OnInitialized()
    {
        allIcons =
        [
            .. Libraries
                .SelectMany(EnumerateIcons)
                .OrderBy(entry => entry.Icon.Name, StringComparer.OrdinalIgnoreCase)
                .ThenBy(entry => entry.Library, StringComparer.OrdinalIgnoreCase)
        ];

        libraryCounts =
        [
            .. allIcons
                .GroupBy(entry => entry.Library)
                .Select(group => (Library: group.Key, Count: group.Count()))
                .OrderBy(group => group.Library, StringComparer.OrdinalIgnoreCase)
        ];

        RefreshResults();
    }

    private static IEnumerable<IconEntry> EnumerateIcons(IconLibraryDefinition library)
    {
        foreach (var iconName in library.IconNames)
        {
            var icon = library.FromName(iconName);
            if (icon is null)
            {
                continue;
            }

            yield return new IconEntry(
                library.Name,
                icon,
                new HashSet<string> { Normalize($"{library.Name} {icon.Name}") },
                Normalize(icon.Name));
        }
    }

    private void RefreshResults()
    {
        var term = searchText.Trim();

        fuzzyMatches = Array.Empty<string>();
        usingFuzzyMatches = false;

        if (string.IsNullOrWhiteSpace(term))
        {
            filteredIcons = [.. allIcons];
            return;
        }

        var normalizedTerm = Normalize(term);
        if (normalizedTerm.Length == 0)
        {
            filteredIcons = [.. allIcons];
            return;
        }

        var directMatches = allIcons
            .Where(entry => entry.Contains(normalizedTerm))
            .ToArray();

        if (directMatches.Length > 0)
        {
            filteredIcons = directMatches;
            return;
        }

        fuzzyMatches = FindClosestNames(normalizedTerm);
        if (fuzzyMatches.Count == 0)
        {
            filteredIcons = Array.Empty<IconEntry>();
            return;
        }

        usingFuzzyMatches = true;

        var fuzzyLookup = new HashSet<string>(fuzzyMatches.Select(Normalize), StringComparer.Ordinal);
        filteredIcons = allIcons
            .Where(entry => fuzzyLookup.Contains(entry.NormalizedName))
            .ToArray();
    }

    private IReadOnlyList<string> FindClosestNames(string normalizedTerm)
    {
        return
        [
            .. allIcons
                .Select(entry => entry.Icon.Name)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .Select(name => new RankedName(name, LevenshteinDistance(normalizedTerm, Normalize(name))))
                .OrderBy(result => result.Distance)
                .ThenBy(result => result.Name, StringComparer.OrdinalIgnoreCase)
                .Take(12)
                .Select(result => result.Name)
        ];
    }

    private static string Normalize(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var builder = new StringBuilder(value.Length);

        foreach (var character in value)
        {
            if (char.IsLetterOrDigit(character))
            {
                builder.Append(char.ToLowerInvariant(character));
            }
        }

        return builder.ToString();
    }

    private static int LevenshteinDistance(string source, string target)
    {
        if (source == target)
        {
            return 0;
        }

        if (source.Length == 0)
        {
            return target.Length;
        }

        if (target.Length == 0)
        {
            return source.Length;
        }

        var previous = new int[target.Length + 1];
        var current = new int[target.Length + 1];

        for (var index = 0; index <= target.Length; index++)
        {
            previous[index] = index;
        }

        for (var sourceIndex = 1; sourceIndex <= source.Length; sourceIndex++)
        {
            current[0] = sourceIndex;

            for (var targetIndex = 1; targetIndex <= target.Length; targetIndex++)
            {
                var cost = source[sourceIndex - 1] == target[targetIndex - 1] ? 0 : 1;

                current[targetIndex] = Math.Min(
                    Math.Min(current[targetIndex - 1] + 1, previous[targetIndex] + 1),
                    previous[targetIndex - 1] + cost);
            }

            (previous, current) = (current, previous);
        }

        return previous[target.Length];
    }

    private sealed record IconLibraryDefinition(
        string Name,
        IReadOnlyList<string> IconNames,
        Func<string, IconDto?> FromName);


    private sealed record RankedName(string Name, int Distance);
}
