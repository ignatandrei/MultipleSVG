<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>true</IsPackable>
    <PackageId>MSvg.All</PackageId>
    <PackageVersion>2026.610.1743</PackageVersion>
    <Authors>Ignat Andrei</Authors>
    <Description>Multiple SVG icon library generated from Lucide, Bootstrap, Heroicons, and glinckerthesvg sources.</Description>
    <PackageTags>svg;icons;blazor;components</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/ignatandrei/MultipleSVG</PackageProjectUrl>
    <RepositoryUrl>https://github.com/ignatandrei/MultipleSVG</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <ContinuousIntegrationBuild Condition="'$(GITHUB_ACTIONS)' == 'true'">true</ContinuousIntegrationBuild>
	  <Features>$(Features);experimental-data-section-string-literals</Features>
  </PropertyGroup>
	<ItemGroup>
		<PackageReference Include="Fastenshtein" Version="1.0.12" />
		<PackageReference Include="RSCG_Templating" Version="2026.421.1830" OutputItemType="Analyzer" />
		<PackageReference Include="RSCG_TemplatingCommon" Version="2026.421.1830" />
		<PackageReference Include="SvgIconGenerator" Version="0.0.4">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
	</ItemGroup>
	<ItemGroup>
    <AdditionalFiles Include="Icons/resolvetosavelives_healthicons/*.svg" />
    <AdditionalFiles Include="Icons/framework7io_framework7_icons/*.svg" />
    <AdditionalFiles Include="Icons/microsoft_fluentui_emoji/*.svg" />
    <AdditionalFiles Include="Icons/themesberg_flowbite_icons/*.svg" />
    <AdditionalFiles Include="Icons/icons8_flat_Color_icons/*.svg" />
    <AdditionalFiles Include="Icons/Yummygum_flagpack_core/*.svg" />
    <AdditionalFiles Include="Icons/lipis_flag_icons/*.svg" />
    <AdditionalFiles Include="Icons/feathericon_feathericon/*.svg" />
		<AdditionalFiles Include="Icons/Lucide/*.svg" />
		<AdditionalFiles Include="Icons/Bootstrap/*.svg" />
		<AdditionalFiles Include="Icons/TailwindlabsHeroicons/*.svg" />
		<AdditionalFiles Include="Icons/glinckerthesvg/*.svg" />
		<AdditionalFiles Include="Icons/Azure_Public_Service_Icons/*.svg" />
		<AdditionalFiles Include="Icons/Dynamics_365_App_Icons/*.svg" />
		<AdditionalFiles Include="Icons/Microsoft_365_content_icons/*.svg" />
		<AdditionalFiles Include="Icons/IconNoir/*.svg" />
		<AdditionalFiles Include="Icons/Leungwensen/*.svg" />
		<AdditionalFiles Include="Icons/SustyIcons/*.svg" />
		<AdditionalFiles Include="Icons/AndflettCascade/*.svg" />
		<AdditionalFiles Include="Icons/artcoholic_akar_icons/*.svg" />
		<AdditionalFiles Include="Icons/ant_design_icons/*.svg" />
		<AdditionalFiles Include="Icons/cyberalien_line_md/*.svg" />
		<AdditionalFiles Include="Icons/BitcoinDesign_Bitcoin_Icons/*.svg" />
		<AdditionalFiles Include="Icons/box_icons_boxicons_core/*.svg" />
		<AdditionalFiles Include="Icons/danklammer_bytesize_icons/*.svg" />
		<AdditionalFiles Include="Icons/catppuccin_vscode_icons/*.svg" />
		<AdditionalFiles Include="Icons/jaynewey_charm_icons/*.svg" />
		<AdditionalFiles Include="Icons/HatScripts_circle_flags/*.svg" />
		<AdditionalFiles Include="Icons/vmware_archive_clarity_assets/*.svg" />
		<AdditionalFiles Include="Icons/codex_teamicons/*.svg" />
		<AdditionalFiles Include="Icons/devicons_devicon/*.svg" />
		<AdditionalFiles Include="Icons/fernandcf_duo_icons/*.svg" />
		<AdditionalFiles Include="Icons/element_plus_element_plus_icons/*.svg" />
		<AdditionalFiles Include="Icons/SUSE_UIUX_eos_icons/*.svg" />
		<AdditionalFiles Include="Icons/akveo_eva_icons/*.svg" />
		<AdditionalFiles Include="Icons/evil_icons_evil_icons/*.svg" />
		<AdditionalFiles Include="Icons/familyjs_famicons/*.svg" />
		
	</ItemGroup>
	<ItemGroup>
		<Watch Include="**\*.txt" />
	</ItemGroup>
	<ItemGroup>
		<AdditionalFiles Include="Templating/IconLookupShared.txt" />
	</ItemGroup>
	<ItemGroup>
		<None Include="..\..\..\README.md" Pack="true" PackagePath="\" Link="README.md" />
	</ItemGroup>
	<PropertyGroup>
		<EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
		<CompilerGeneratedFilesOutputPath>$(BaseIntermediateOutputPath)/GX</CompilerGeneratedFilesOutputPath>
	</PropertyGroup>
	<PropertyGroup>
	  <TreatWarningsAsErrors>True</TreatWarningsAsErrors>
	  <WarningsNotAsErrors>NU1900</WarningsNotAsErrors>
	</PropertyGroup>
	
</Project>
